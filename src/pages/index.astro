---
// src/pages/index.astro — Página de inicio
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { categories, getAllProducts } from '../data/products';

const allProducts = await getAllProducts();
const featuredProducts = allProducts.slice(0, 6);
---

<Layout>
  <!-- ══ HERO ══ -->
  <section class="hero">
    <div class="hero-content">
      <span class="hero-badge">Colección 2026</span>
      <h1 class="hero-title">Diseño que transforma<br/>tu espacio</h1>
      <p class="hero-subtitle">
        Muebles exclusivos, joyería artesanal y elementos decorativos
        seleccionados para ti.
      </p>
      <div class="hero-actions">
        <a href="/categorias" class="btn-primary" id="cta-catalogo">Explorar catálogo</a>
        <a href="#destacados" class="btn-ghost" id="cta-destacados">Ver destacados ↓</a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-shape"></div>
    </div>
  </section>

  <!-- ══ CATEGORÍAS ══ -->
  <section class="section container">
    <h2 class="section-title">Categorías</h2>
    <p class="section-subtitle">Explora nuestra selección curada por categoría.</p>

    <div class="categories-grid">
      {categories.map((cat) => (
        <a href={`/categorias/${cat.slug}`} class="category-card" id={`cat-${cat.slug}`}>
          <div class="category-bg" style={`background-image: url('${cat.image}')`}></div>
          <div class="category-overlay">
            <h3>{cat.name}</h3>
            <p>{cat.description}</p>
            <span class="category-cta">Ver productos →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ══ PRODUCTOS DESTACADOS ══ -->
  <section class="section container" id="destacados">
    <h2 class="section-title">Productos Destacados</h2>
    <p class="section-subtitle">Lo más nuevo de nuestra colección.</p>

    <div class="featured-grid">
      {featuredProducts.map((product) => (
        <ProductCard product={product} />
      ))}
    </div>

    <div class="view-all">
      <a href="/categorias" class="btn-secondary" id="ver-todo">Ver todo el catálogo →</a>
    </div>
  </section>
</Layout>

<style>
  /* ── HERO ── */
  .hero {
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #faf8f5 0%, #f0ede8 50%, #e8e0d8 100%);
    padding: 2rem;
  }

  .hero-content {
    max-width: 640px;
    text-align: center;
    z-index: 2;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(139, 94, 60, 0.1);
    color: #8b5e3c;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.4rem 1.2rem;
    border-radius: 50px;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    color: #1a1a1a;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: #666;
    max-width: 480px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-visual {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-shape {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(139, 94, 60, 0.06) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  /* ── Botones ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: #1a1a1a;
    color: #fff;
    padding: 0.9rem 2rem;
    border-radius: 12px;
    font-size: 0.95rem;
    font-weight: 600;
    transition: all 0.25s ease;
    text-decoration: none;
  }

  .btn-primary:hover {
    background: #8b5e3c;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(139, 94, 60, 0.25);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: #555;
    padding: 0.9rem 2rem;
    border-radius: 12px;
    font-size: 0.95rem;
    font-weight: 500;
    border: 1.5px solid #ddd;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .btn-ghost:hover {
    border-color: #8b5e3c;
    color: #8b5e3c;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    color: #8b5e3c;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: gap 0.2s;
    gap: 0.25rem;
  }

  .btn-secondary:hover {
    gap: 0.5rem;
  }

  /* ── Categorías ── */
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .category-card {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    text-decoration: none;
    color: #fff;
  }

  .category-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-color: #d4a373;
    transition: transform 0.5s ease;
  }

  .category-card:hover .category-bg {
    transform: scale(1.08);
  }

  .category-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.1) 60%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem;
  }

  .category-overlay h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }

  .category-overlay p {
    font-size: 0.85rem;
    opacity: 0.85;
    margin-bottom: 0.75rem;
  }

  .category-cta {
    font-size: 0.85rem;
    font-weight: 600;
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.3s ease;
  }

  .category-card:hover .category-cta {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Productos destacados ── */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .view-all {
    text-align: center;
    margin-top: 3rem;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .categories-grid,
    .featured-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: 70vh;
    }
    .categories-grid,
    .featured-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
