---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProductGrid from '../components/ProductGrid.astro';

// mock categories
const categories = [
  { name: 'Sofas', image: '🛋️' },
  { name: 'Beds', image: '🛏️' },
  { name: 'Tables', image: '🪑' },
  { name: 'Storage', image: '📦' },
  { name: 'Kitchen', image: '🍳' },
  { name: 'Decor', image: '🖼️' },
  { name: 'Lighting', image: '💡' },
  { name: 'Textiles', image: '🧵' },
];
---

<Layout title="NORDY. | Beautiful Minimal Design Home">
	<Hero />
  
  <section class="categories-section container">
    <div class="category-scroll">
      {categories.map(cat => (
        <a href="#" class="category-item">
          <div class="category-icon">{cat.image}</div>
          <span class="category-name">{cat.name}</span>
        </a>
      ))}
    </div>
  </section>

  <ProductGrid />

  <!-- Promo banner like Casa Ideas / Ikea often uses -->
  <section class="promo-banner container">
    <div class="promo-content">
      <h2>Join NORDY Family</h2>
      <p>Get exclusive discounts, early access to new collections, and inspiring home styling ideas.</p>
      <button class="btn btn-primary" aria-label="Join family">Join for free</button>
    </div>
  </section>
  
  <ProductGrid title="Just Arrived" subtitle="Fresh new designs to inspire you." />
</Layout>

<style>
  .categories-section {
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .category-scroll {
    display: flex;
    gap: 2rem;
    overflow-x: auto;
    padding-bottom: 1rem;
    scrollbar-width: none; /* Firefox */
  }

  .category-scroll::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .category-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    min-width: 80px;
    transition: transform var(--transition-fast);
  }

  .category-item:hover {
    transform: translateY(-5px);
  }

  .category-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background-color: var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    transition: background-color var(--transition-fast);
  }

  .category-item:hover .category-icon {
    background-color: var(--color-border);
  }

  .category-name {
    font-size: 0.9rem;
    font-weight: 600;
  }

  /* Promo Banner */
  .promo-banner {
    margin-top: 3rem;
    margin-bottom: 3rem;
  }

  .promo-content {
    background-color: #fce2c2; /* Warm inviting color, common in Casa ideas */
    padding: 4rem;
    border-radius: var(--radius-lg);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .promo-content h2 {
    font-size: 2.5rem;
    color: #a45a1c;
    letter-spacing: -1px;
  }

  .promo-content p {
    font-size: 1.1rem;
    max-width: 600px;
    color: #a45a1c;
  }

  .promo-content .btn {
    background-color: #a45a1c;
    color: white;
    font-size: 1.1rem;
    padding: 1rem 2.5rem;
  }

  .promo-content .btn:hover {
    background-color: #7b4315;
  }

  @media (max-width: 768px) {
    .promo-content {
      padding: 2.5rem 1.5rem;
    }
    .promo-content h2 {
      font-size: 2rem;
    }
  }
</style>
