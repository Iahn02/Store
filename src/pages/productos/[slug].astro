---
// src/pages/productos/[slug].astro
import Layout from '../../layouts/Layout.astro';
import { getProductBySlug, getAllProducts } from '../../data/products';

export async function getStaticPaths() {
  const products = await getAllProducts();
  return products.map((p) => ({
    params: { slug: p.slug },
  }));
}

const { slug } = Astro.params;
const product = await getProductBySlug(slug!);

if (!product) {
  return new Response(null, { status: 404, statusText: 'Producto no encontrado' });
}

// Formatear precio
const formattedPrice = new Intl.NumberFormat('es-CL', {
  style: 'currency',
  currency: product.currency,
  minimumFractionDigits: 0,
}).format(product.price);

---

<Layout
  title={`${product.name} | NORDY.`}
  description={product.description}
>
  <main class="product-detail container">
    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <a href="/">Inicio</a>
      <span class="sep">/</span>
      <a href={`/categorias/${product.categorySlug}`}>
        {product.category}
      </a>
      <span class="sep">/</span>
      <span class="current">{product.name}</span>
    </nav>

    <!-- Producto -->
    <div class="product-container">
      <div class="product-gallery">
        <div class="gallery-main">
          {product.isNew && <span class="badge new-badge">Nuevo</span>}
          <img
            src={product.image}
            alt={product.name}
            loading="eager"
            id="product-main-image"
          />
        </div>
      </div>

      <div class="product-info">
        <span class="product-category">
          {product.category}
        </span>

        <h1 id="product-title">{product.name}</h1>
        <p class="product-price" id="product-price">{formattedPrice}</p>
        <p class="product-description">{product.description}</p>

        <div class="product-features">
          <h3>Características principales</h3>
          <ul>
            {product.features.map((feature) => (
              <li>
                <span class="check">✓</span>
                {feature}
              </li>
            ))}
          </ul>
        </div>

        <div class="product-actions">
          <button class="btn btn-primary btn-add-cart" id="add-to-cart" data-id={product.id} data-name={product.name} data-price={product.price} data-image={product.image}>
            Añadir a la bolsa
          </button>
        </div>
        
        <div class="delivery-info">
          <div class="info-row">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
            <span>Despacho a domicilio disponible.</span>
          </div>
          <div class="info-row">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
            <span>Retiro en tienda disponible.</span>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Simple Cart Logic using localStorage
  const addToCartBtn = document.getElementById('add-to-cart');
  
  if (addToCartBtn) {
    addToCartBtn.addEventListener('click', () => {
      const product = {
        id: addToCartBtn.getAttribute('data-id'),
        name: addToCartBtn.getAttribute('data-name'),
        price: Number(addToCartBtn.getAttribute('data-price')),
        image: addToCartBtn.getAttribute('data-image'),
        quantity: 1
      };
      
      let cart = JSON.parse(localStorage.getItem('nordy_cart') || '[]');
      
      const existingProductIndex = cart.findIndex((p: any) => p.id === product.id);
      if (existingProductIndex >= 0) {
        cart[existingProductIndex].quantity += 1;
      } else {
        cart.push(product);
      }
      
      localStorage.setItem('nordy_cart', JSON.stringify(cart));
      
      // Update badge
      const badge = document.querySelector('.cart-badge');
      if (badge) {
        const totalItems = cart.reduce((acc: number, item: any) => acc + item.quantity, 0);
        badge.textContent = totalItems.toString();
        badge.classList.add('bump');
        setTimeout(() => badge.classList.remove('bump'), 300);
      }
      
      // visual feedback
      addToCartBtn.textContent = '¡Añadido!';
      setTimeout(() => {
        addToCartBtn.textContent = 'Añadir a la bolsa';
      }, 2000);
    });
  }
</script>

<style>
  .product-detail {
    padding-top: 2rem;
    padding-bottom: 5rem;
  }

  /* ── Breadcrumb ── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text-light);
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--color-primary);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .breadcrumb .sep {
    color: var(--color-border);
  }

  .breadcrumb .current {
    font-weight: 500;
  }

  /* ── Grid producto ── */
  .product-container {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  /* ── Galería ── */
  .gallery-main {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface);
    position: relative;
    aspect-ratio: 4/5;
  }

  .gallery-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .new-badge {
    position: absolute;
    top: 20px;
    left: 20px;
    background-color: var(--color-white);
    color: var(--color-primary);
    font-size: 0.8rem;
    font-weight: 700;
    padding: 6px 12px;
    border-radius: 4px;
    text-transform: uppercase;
    z-index: 2;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  /* ── Info producto ── */
  .product-category {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-light);
    margin-bottom: 1rem;
    display: block;
  }

  h1 {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-primary);
    margin-bottom: 1rem;
    letter-spacing: -1.5px;
  }

  .product-price {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 2rem;
  }

  .product-description {
    font-size: 1.1rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }

  /* ── Features ── */
  .product-features h3 {
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .product-features ul {
    list-style: none;
    padding: 0;
    margin-bottom: 3rem;
  }

  .product-features li {
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-light);
    font-size: 1rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .check {
    color: var(--color-primary);
    font-weight: 700;
    font-size: 1rem;
  }

  /* ── Actions ── */
  .btn-add-cart {
    width: 100%;
    padding: 1.2rem;
    font-size: 1.1rem;
    margin-bottom: 2rem;
    transition: all 0.3s ease;
  }

  /* ── Delivery Info ── */
  .delivery-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
  }
  
  .info-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--color-primary);
    font-weight: 500;
    font-size: 0.95rem;
  }

  /* ── Responsive ── */
  @media (max-width: 992px) {
    .product-container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    h1 { font-size: 2.5rem; }
  }
</style>
