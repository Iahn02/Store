---
// src/pages/productos/[slug].astro
// Ruta dinámica SSR — Detalle de producto individual.
// Se renderiza en el servidor en cada request.

import Layout from '../../layouts/Layout.astro';
import { getProductBySlug } from '../../data/products';

// 1. Obtener el slug desde la URL
const { slug } = Astro.params;

// 2. Buscar el producto
const product = await getProductBySlug(slug!);

// 3. 404 si no existe
if (!product) {
  return new Response(null, {
    status: 404,
    statusText: 'Producto no encontrado',
  });
}

// 4. Formatear precio
const formattedPrice = new Intl.NumberFormat('es-CL', {
  style: 'currency',
  currency: product.currency,
  minimumFractionDigits: 0,
}).format(product.price);

// 5. Labels legibles
const categoryLabels: Record<string, string> = {
  muebles: 'Muebles',
  joyeria: 'Joyería',
  decoracion: 'Decoración',
};
const subcategoryLabels: Record<string, string> = {
  lamparas: 'Lámparas',
  espejos: 'Espejos',
};

// 6. JSON-LD para SEO (datos estructurados Schema.org)
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  image: product.image,
  offers: {
    '@type': 'Offer',
    price: product.price,
    priceCurrency: product.currency,
    availability: 'https://schema.org/InStock',
  },
};
---

<Layout
  title={`${product.name} | Mi Tienda`}
  description={product.description}
  image={product.image}
  type="product"
>
  <main class="product-detail container">
    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <a href="/">Inicio</a>
      <span class="sep">/</span>
      <a href={`/categorias/${product.category}`}>
        {categoryLabels[product.category]}
      </a>
      {product.subcategory && (
        <>
          <span class="sep">/</span>
          <a href={`/categorias/${product.category}/${product.subcategory}`}>
            {subcategoryLabels[product.subcategory]}
          </a>
        </>
      )}
      <span class="sep">/</span>
      <span class="current">{product.name}</span>
    </nav>

    <!-- Producto -->
    <div class="product-container">
      <div class="product-gallery">
        <div class="gallery-main">
          <img
            src={product.image}
            alt={product.name}
            loading="eager"
            id="product-main-image"
          />
        </div>
      </div>

      <div class="product-info">
        <span class="product-category">
          {categoryLabels[product.category]}
          {product.subcategory && ` · ${subcategoryLabels[product.subcategory]}`}
        </span>

        <h1 id="product-title">{product.name}</h1>
        <p class="product-price" id="product-price">{formattedPrice}</p>
        <p class="product-description">{product.description}</p>

        <div class="product-features">
          <h3>Características</h3>
          <ul>
            {product.features.map((feature) => (
              <li>
                <span class="check">✓</span>
                {feature}
              </li>
            ))}
          </ul>
        </div>

        <div class="product-actions">
          <button class="btn-primary" id="add-to-cart">
            Agregar al carrito
          </button>
          <button class="btn-whatsapp" id="contact-whatsapp">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            Consultar por WhatsApp
          </button>
        </div>
      </div>
    </div>
  </main>

  <!-- JSON-LD para SEO -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Layout>

<style>
  .product-detail {
    padding-top: 2rem;
    padding-bottom: 4rem;
  }

  /* ── Breadcrumb ── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: #999;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: #8b5e3c;
    transition: opacity 0.2s;
  }

  .breadcrumb a:hover {
    opacity: 0.7;
  }

  .breadcrumb .sep {
    color: #ddd;
  }

  .breadcrumb .current {
    color: #555;
    font-weight: 500;
  }

  /* ── Grid producto ── */
  .product-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* ── Galería ── */
  .gallery-main {
    border-radius: 20px;
    overflow: hidden;
    background: #f0ede8;
  }

  .gallery-main img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .gallery-main:hover img {
    transform: scale(1.03);
  }

  /* ── Info producto ── */
  .product-category {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8b5e3c;
    background: rgba(139, 94, 60, 0.08);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.2;
    color: #1a1a1a;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .product-price {
    font-size: 1.75rem;
    font-weight: 700;
    color: #8b5e3c;
    margin-bottom: 1.25rem;
  }

  .product-description {
    font-size: 1rem;
    color: #666;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  /* ── Features ── */
  .product-features h3 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #999;
    margin-bottom: 0.75rem;
  }

  .product-features ul {
    list-style: none;
    padding: 0;
    margin-bottom: 2rem;
  }

  .product-features li {
    padding: 0.65rem 0;
    border-bottom: 1px solid #f0f0f0;
    color: #444;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .check {
    color: #8b5e3c;
    font-weight: 700;
    font-size: 0.85rem;
  }

  /* ── Actions ── */
  .product-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    flex: 1;
    min-width: 180px;
    background: #1a1a1a;
    color: #fff;
    border: none;
    padding: 1rem 2rem;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .btn-primary:hover {
    background: #8b5e3c;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(139, 94, 60, 0.25);
  }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    color: #25d366;
    border: 2px solid #25d366;
    padding: 1rem 1.5rem;
    border-radius: 12px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-whatsapp:hover {
    background: #25d366;
    color: #fff;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .product-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    h1 {
      font-size: 1.75rem;
    }

    .product-price {
      font-size: 1.5rem;
    }

    .product-actions {
      flex-direction: column;
    }
  }
</style>
