---
// src/pages/categorias/index.astro
import Layout from '../../layouts/Layout.astro';
import { categories } from '../../data/products';
---

<Layout
  title="Todas las Categorías | NORDY."
  description="Explora todas nuestras categorías y encuentra el estilo ideal para tu hogar."
>
  <main class="container section">
    <div class="header-section">
      <h1 class="page-title">Explora nuestro catálogo</h1>
      <p class="page-subtitle">Diseños cuidadosamente seleccionados para cada espacio de tu hogar.</p>
    </div>

    <div class="categories-grid">
      {categories.map((cat) => (
        <a href={`/categorias/${cat.slug}`} class="category-card">
          <div class="cat-image">
            <img src={cat.image} alt={cat.name} loading="lazy" />
          </div>
          <div class="cat-info">
            <span class="cat-icon">{cat.icon}</span>
            <div class="cat-text">
              <h3>{cat.name}</h3>
              <p>{cat.description}</p>
            </div>
            <span class="arrow-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>

<style>
  .section {
    padding-top: 4rem;
    padding-bottom: 6rem;
  }

  .header-section {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 4rem auto;
  }

  .page-title {
    font-size: 3rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
    letter-spacing: -1.5px;
  }

  .page-subtitle {
    font-size: 1.2rem;
    color: var(--color-text-light);
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .category-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .category-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }

  .cat-image {
    height: 240px;
    overflow: hidden;
  }

  .cat-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .category-card:hover .cat-image img {
    transform: scale(1.05);
  }

  .cat-info {
    padding: 2rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .cat-icon {
    font-size: 2.5rem;
  }

  .cat-text {
    flex: 1;
  }

  .cat-text h3 {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .cat-text p {
    font-size: 0.95rem;
    color: var(--color-text-light);
    line-height: 1.4;
  }

  .arrow-icon {
    color: var(--color-border);
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  .category-card:hover .arrow-icon {
    color: var(--color-primary);
    transform: translateX(5px);
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2.5rem;
    }
  }
</style>
