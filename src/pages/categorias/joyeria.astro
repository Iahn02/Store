---
// src/pages/categorias/joyeria.astro
import Layout from '../../layouts/Layout.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import CategoryMenu from '../../components/CategoryMenu.astro';
import { getProducts } from '../../data/products';

const products = await getProducts('joyeria');
---

<Layout
  title="Joyería | Mi Tienda — Diseños Únicos"
  description="Joyería artesanal con diseños únicos. Anillos, collares y pulseras en plata 925 y oro."
>
  <main class="container section">
    <h1 class="section-title">Joyería</h1>
    <p class="section-subtitle">Joyería artesanal con diseños únicos y materiales de primera.</p>

    <div class="catalog-layout">
      <CategoryMenu activeCategory="joyeria" />
      <div class="catalog-main">
        <p class="results-count">{products.length} productos</p>
        <ProductGrid products={products} />
      </div>
    </div>
  </main>
</Layout>

<style>
  .catalog-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 2rem;
    align-items: start;
  }

  .results-count {
    font-size: 0.85rem;
    color: #999;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .catalog-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
