---
// src/pages/carrito.astro
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Tu Bolsa | NORDY."
  description="Revisa los productos en tu bolsa de compras."
>
  <main class="container cart-section">
    <div class="cart-header">
      <h1 class="page-title">Tu Bolsa</h1>
      <span class="item-count" id="header-item-count">0 items</span>
    </div>

    <div class="cart-layout">
      <!-- Cart Items -->
      <div class="cart-items" id="cart-container">
        <!-- Renderizado por JS -->
      </div>

      <!-- Order Summary -->
      <div class="order-summary">
        <h3>Resumen del Pedido</h3>
        
        <div class="summary-rows">
          <div class="row">
            <span>Subtotal</span>
            <span id="summary-subtotal">$0</span>
          </div>
          <div class="row">
            <span>Despacho</span>
            <span>Calculado en checkout</span>
          </div>
          <hr class="divider" />
          <div class="row total">
            <span>Total</span>
            <span id="summary-total">$0</span>
          </div>
        </div>

        <button class="btn btn-primary btn-checkout" disabled id="btn-checkout">Continuar al pago</button>
        
        <div class="return-policy">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
          <p>Devoluciones gratuitas dentro de los 30 días posteriores a la compra. Se aplican ciertas exclusiones.</p>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  function formatMoney(amount: number) {
    return new Intl.NumberFormat('es-CL', {
      style: 'currency',
      currency: 'CLP',
      minimumFractionDigits: 0
    }).format(amount);
  }

  function renderCart() {
    const cartContainer = document.getElementById('cart-container');
    const headerCount = document.getElementById('header-item-count');
    const subtotalEl = document.getElementById('summary-subtotal');
    const totalEl = document.getElementById('summary-total');
    const btnCheckout = document.getElementById('btn-checkout') as HTMLButtonElement;
    
    // Obtener carrito de localstorage
    const cart = JSON.parse(localStorage.getItem('nordy_cart') || '[]');
    
    // Actualizar cantidades globales
    const totalItems = cart.reduce((acc: number, item: any) => acc + item.quantity, 0);
    const totalPrice = cart.reduce((acc: number, item: any) => acc + (item.price * item.quantity), 0);
    
    if (headerCount) headerCount.textContent = `${totalItems} ítem${totalItems !== 1 ? 's' : ''}`;
    if (subtotalEl) subtotalEl.textContent = formatMoney(totalPrice);
    if (totalEl) totalEl.textContent = formatMoney(totalPrice);
    
    // Actualizar badge del header
    const badge = document.querySelector('.cart-badge');
    if (badge) badge.textContent = totalItems.toString();
    
    if (!cartContainer) return;
    
    // Limpiar container
    cartContainer.innerHTML = '';
    
    if (cart.length === 0) {
      cartContainer.innerHTML = `
        <div class="empty-cart">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
          <h2>Tu bolsa está vacía</h2>
          <p>Parece que aún no has añadido artículos. Explora nuestro catálogo y descubre productos increíbles.</p>
          <a href="/categorias" class="btn btn-primary" style="margin-top:2rem;">Empezar a comprar</a>
        </div>
      `;
      if (btnCheckout) btnCheckout.disabled = true;
      return;
    }
    
    if (btnCheckout) btnCheckout.disabled = false;
    
    cart.forEach((item: any, index: number) => {
      const el = document.createElement('div');
      el.className = 'cart-item';
      el.innerHTML = `
        <div class="item-img">
          <img src="${item.image}" alt="${item.name}">
        </div>
        <div class="item-details">
          <div class="item-title-row">
            <a href="/productos/${item.id}" class="item-name">${item.name}</a>
            <span class="item-price">${formatMoney(item.price)}</span>
          </div>
          <div class="item-actions">
            <div class="quantity-control">
              <button class="btn-qty btn-minus" data-idx="${index}">-</button>
              <span class="qty">${item.quantity}</span>
              <button class="btn-qty btn-plus" data-idx="${index}">+</button>
            </div>
            <button class="btn-remove" data-idx="${index}">Eliminar</button>
          </div>
        </div>
      `;
      cartContainer.appendChild(el);
    });
    
    // Asignar listeners a botones nuevos
    const btnMinus = document.querySelectorAll('.btn-minus');
    btnMinus.forEach(b => b.addEventListener('click', (e) => updateQuantity(e, -1)));
    
    const btnPlus = document.querySelectorAll('.btn-plus');
    btnPlus.forEach(b => b.addEventListener('click', (e) => updateQuantity(e, 1)));
    
    const btnRemove = document.querySelectorAll('.btn-remove');
    btnRemove.forEach(b => b.addEventListener('click', removeCartItem));
  }
  
  function updateQuantity(e: Event, change: number) {
    const target = e.currentTarget as HTMLButtonElement;
    const idx = Number(target.getAttribute('data-idx'));
    let cart = JSON.parse(localStorage.getItem('nordy_cart') || '[]');
    
    if (cart[idx]) {
      cart[idx].quantity += change;
      if (cart[idx].quantity <= 0) {
        cart.splice(idx, 1);
      }
      localStorage.setItem('nordy_cart', JSON.stringify(cart));
      renderCart();
    }
  }
  
  function removeCartItem(e: Event) {
    const target = e.currentTarget as HTMLButtonElement;
    const idx = Number(target.getAttribute('data-idx'));
    let cart = JSON.parse(localStorage.getItem('nordy_cart') || '[]');
    
    if (cart[idx]) {
      cart.splice(idx, 1);
      localStorage.setItem('nordy_cart', JSON.stringify(cart));
      renderCart();
    }
  }
  
  document.getElementById('btn-checkout')?.addEventListener('click', () => {
    alert('Función de pago (Fake Flow) - Redirigiendo a pasarela...');
  });

  // Ejecutar renderizado al cargar
  renderCart();
</script>

<style>
  .cart-section {
    padding-top: 4rem;
    padding-bottom: 6rem;
  }

  .cart-header {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: 3rem;
    color: var(--color-primary);
    letter-spacing: -1.5px;
  }

  .item-count {
    color: var(--color-text-light);
    font-size: 1.1rem;
    font-weight: 500;
  }

  .cart-layout {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Items */
  .cart-items {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .cart-item {
    display: flex;
    gap: 2rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2rem;
  }

  .item-img {
    width: 140px;
    height: 140px;
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
    flex-shrink: 0;
  }

  .item-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .item-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .item-title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .item-name {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    max-width: 70%;
  }
  
  .item-name:hover {
    text-decoration: underline;
  }

  .item-price {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .item-actions {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .quantity-control {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .btn-qty {
    background: transparent;
    border: none;
    color: var(--color-primary);
    width: 36px;
    height: 36px;
    font-size: 1.2rem;
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .btn-qty:hover {
    background: var(--color-surface);
  }

  .qty {
    width: 40px;
    text-align: center;
    font-weight: 600;
  }

  .btn-remove {
    background: none;
    border: none;
    color: var(--color-text-light);
    font-weight: 600;
    text-decoration: underline;
    cursor: pointer;
  }

  .btn-remove:hover {
    color: var(--color-primary);
  }

  /* Empty Cart */
  .empty-cart {
    text-align: center;
    padding: 4rem 2rem;
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    color: var(--color-text-light);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .empty-cart svg {
    margin-bottom: 1rem;
    opacity: 0.5;
  }

  .empty-cart h2 {
    color: var(--color-primary);
    font-size: 2rem;
  }
  
  .empty-cart p {
    max-width: 400px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Order Summary */
  .order-summary {
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    position: sticky;
    top: 120px;
  }

  .order-summary h3 {
    font-size: 1.4rem;
    color: var(--color-primary);
    margin-bottom: 2rem;
  }

  .summary-rows {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    margin-bottom: 2.5rem;
  }

  .row {
    display: flex;
    justify-content: space-between;
    color: var(--color-text-light);
    font-size: 1.05rem;
  }

  .divider {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 0.5rem 0;
  }

  .row.total {
    color: var(--color-primary);
    font-weight: 700;
    font-size: 1.3rem;
  }

  .btn-checkout {
    width: 100%;
    padding: 1.2rem;
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .btn-checkout:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .return-policy {
    display: flex;
    gap: 1rem;
    color: var(--color-text-light);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .return-policy svg {
    flex-shrink: 0;
    opacity: 0.6;
  }

  @media (max-width: 992px) {
    .cart-layout {
      grid-template-columns: 1fr;
    }
    .order-summary {
      position: static;
    }
  }

  @media (max-width: 576px) {
    .cart-item {
      flex-direction: column;
    }
    .item-img {
      width: 100%;
      height: 200px;
    }
    .page-title {
      font-size: 2.5rem;
    }
  }
</style>
