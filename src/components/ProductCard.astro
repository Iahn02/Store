---
export interface Props {
  id: string;
  title: string;
  category: string;
  price: number;
  image: string;
  isNew?: boolean;
}

const { title, category, price, image, isNew = false } = Astro.props;

// format price
const formattedPrice = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  minimumFractionDigits: 0
}).format(price);
---

<article class="product-card group">
  <!-- Image Wrapper -->
  <div class="image-wrapper">
    {isNew && <span class="badge new-badge">New</span>}
    <img 
      src={image} 
      alt={title} 
      loading="lazy" 
      class="product-image"
    />
    
    <!-- Quick Add Button Overlay -->
    <button class="quick-add-btn" aria-label="Add to cart">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="cart-icon" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
      <span>Add</span>
    </button>
  </div>

  <!-- Content -->
  <div class="product-info">
    <div class="product-header">
      <h3 class="product-title">{title}</h3>
      <button class="favorite-btn" aria-label="Add to favorites">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
      </button>
    </div>
    
    <p class="product-category">{category}</p>
    <div class="product-price">
      {formattedPrice}
    </div>
  </div>
</article>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    cursor: pointer;
  }

  .image-wrapper {
    position: relative;
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    aspect-ratio: 1;
    overflow: hidden;
  }

  .product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .product-card:hover .product-image {
    transform: scale(1.05);
  }

  .new-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background-color: #12805c; /* green highlight */
    color: white;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 700;
    z-index: 10;
    text-transform: uppercase;
  }

  /* Quick Add overlay button */
  .quick-add-btn {
    position: absolute;
    bottom: -3rem; /* Hide initially */
    left: 1rem;
    right: 1rem;
    background-color: var(--color-primary);
    color: var(--color-white);
    padding: 0.8rem;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-weight: 600;
    transition: bottom 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    z-index: 10;
  }

  .product-card:hover .quick-add-btn {
    bottom: 1rem; /* Show on hover */
  }

  .quick-add-btn:hover {
    background-color: #333;
    transform: translateY(-2px);
  }

  /* Info styling */
  .product-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .product-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .product-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .favorite-btn {
    color: var(--color-text-light);
    background: white;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: all var(--transition-fast);
    box-shadow: var(--shadow-sm);
  }

  .favorite-btn:hover {
    color: var(--color-primary);
    transform: scale(1.1);
  }

  .favorite-btn:active svg {
    fill: var(--color-primary);
  }

  .product-category {
    font-size: 0.9rem;
    color: var(--color-text-light);
  }

  .product-price {
    font-size: 1.3rem;
    font-weight: 800;
    margin-top: 0.3rem;
    color: var(--color-primary);
  }
</style>
