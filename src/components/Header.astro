---
---

<header class="header">
  <div class="header-top container">
    <!-- Mobile menu icon (hidden on larger screens for simplicity) -->
    <button class="btn-icon mobile-only" aria-label="Menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>

    <!-- Logo -->
    <a href="/" class="logo">
      NORDY<span class="dot">.</span>
    </a>

    <!-- Search Bar -->
    <div class="search-container">
      <div class="search-box">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="search-icon" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="text" placeholder="¿Qué estás buscando hoy?" class="search-input" />
      </div>
    </div>

    <!-- Actions: User, Favorites, Cart -->
    <div class="header-actions">
      <a href="/perfil" class="actions-btn" aria-label="Perfil">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        <span class="action-text">Perfil</span>
      </a>

      <a href="/favoritos" class="actions-btn" aria-label="Favoritos">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
        <span class="action-text">Favoritos</span>
      </a>

      <a href="/carrito" class="actions-btn cart-btn" aria-label="Carrito">
        <div class="cart-icon-wrapper">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
          <span class="cart-badge">3</span>
        </div>
        <span class="action-text">Carrito</span>
      </a>
    </div>
  </div>

  <!-- Main Navigation Links -->
  <nav class="main-nav container">
    <ul class="nav-links">
      <li><a href="/categorias">Muebles</a><div class="hover-line"></div></li>
      <li><a href="/categorias">Decoración</a><div class="hover-line"></div></li>
      <li><a href="/categorias">Organización</a><div class="hover-line"></div></li>
      <li><a href="/categorias">Iluminación</a><div class="hover-line"></div></li>
      <li><a href="/categorias">Textiles</a><div class="hover-line"></div></li>
      <li><a href="/ofertas" class="sale-link">Ofertas</a><div class="hover-line"></div></li>
    </ul>
  </nav>
</header>

<script>
  function updateCartBadge() {
    const cart = JSON.parse(localStorage.getItem('nordy_cart') || '[]');
    const totalItems = cart.reduce((acc: number, item: any) => acc + item.quantity, 0);
    const badge = document.querySelector('.cart-badge');
    if (badge) {
      badge.textContent = totalItems.toString();
    }
  }

  // Update on initial load
  updateCartBadge();
  
  // Listen for changes from other tabs or pages
  window.addEventListener('storage', (e) => {
    if (e.key === 'nordy_cart') {
      updateCartBadge();
    }
  });
</script>

<style>
  .header {
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    padding-bottom: 1rem;
    gap: 2rem;
  }

  .logo {
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: -1px;
    display: flex;
    align-items: baseline;
    color: var(--color-primary);
  }
  
  .logo .dot {
    color: var(--color-secondary);
    font-size: 2.2rem;
    line-height: 0;
  }

  /* Search */
  .search-container {
    flex: 1;
    max-width: 600px;
    position: relative;
  }

  .search-box {
    display: flex;
    align-items: center;
    background-color: var(--color-surface);
    border-radius: var(--radius-full);
    padding: 0.7rem 1.2rem;
    transition: background-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .search-box:focus-within {
    background-color: var(--color-white);
    box-shadow: 0 0 0 2px var(--color-primary);
  }

  .search-icon {
    color: var(--color-text-light);
    margin-right: 0.8rem;
  }

  .search-input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 1rem;
    font-family: inherit;
    outline: none;
    color: var(--color-primary);
  }

  /* Actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .actions-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    color: var(--color-primary);
    transition: color var(--transition-fast);
    text-decoration: none;
  }

  .actions-btn:hover {
    color: var(--color-secondary);
  }

  .action-text {
    font-size: 0.75rem;
    font-weight: 500;
  }

  .cart-icon-wrapper {
    position: relative;
  }

  .cart-badge {
    position: absolute;
    top: -6px;
    right: -10px;
    background-color: #d11243; /* Casa Ideas/Ikea typical red/yellow notification*/
    color: white;
    font-size: 0.65rem;
    font-weight: 700;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--color-white);
  }

  /* Main Nav */
  .main-nav {
    padding-bottom: 0.5rem;
    overflow-x: auto;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
    white-space: nowrap;
  }

  .nav-links li {
    position: relative;
  }

  .nav-links a {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-primary);
    padding: 0.5rem 0;
    display: inline-block;
  }

  .nav-links .sale-link {
    color: #d11243; /* highlight red */
  }

  .hover-line {
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 0%;
    height: 2px;
    background-color: var(--color-primary);
    transition: width var(--transition-fast);
  }
  
  .nav-links li:hover .hover-line {
    width: 100%;
  }

  .mobile-only {
    display: none;
  }

  @media (max-width: 768px) {
    .mobile-only { display: flex; }
    .action-text { display: none; }
    .search-container { order: 3; max-width: 100%; margin-top: 1rem; }
    .header-top { flex-wrap: wrap; gap: 1rem; }
  }
</style>
