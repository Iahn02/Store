---
import ProductCard from './ProductCard.astro';
import { getProducts, Product } from '../data/products';

export interface Props {
  title?: string;
  subtitle?: string;
  limit?: number;
  products?: Product[];
}

const { 
  title = "Tendencias", 
  subtitle = "Piezas seleccionadas para elevar tu espacio.", 
  limit = 8,
  products: _propsProducts
} = Astro.props;

// Use provided products or fetch all and slice
let displayProducts = _propsProducts;
if (!displayProducts) {
  const allProducts = await getProducts();
  displayProducts = allProducts.slice(0, limit);
}

---

<section class="product-grid-section container">
  <div class="section-header">
    <div class="titles">
      <h2 class="section-title">{title}</h2>
      <p class="section-subtitle">{subtitle}</p>
    </div>
    <a href="/categorias" class="view-all-link">
      Ver todos los productos
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>

  <div class="grid">
    {displayProducts.map((product) => (
      <ProductCard 
        id={product.id}
        slug={product.slug}
        title={product.name}
        category={product.category}
        price={product.price}
        image={product.image}
        isNew={product.isNew}
      />
    ))}
  </div>
</section>

<style>
  .product-grid-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-size: 2.2rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    letter-spacing: -1px;
  }

  .section-subtitle {
    color: var(--color-text-light);
    font-size: 1.1rem;
  }

  .view-all-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: var(--color-primary);
    font-size: 1rem;
    transition: gap var(--transition-fast);
    text-decoration: none;
  }

  .view-all-link:hover {
    gap: 0.8rem;
    text-decoration: underline;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2.5rem 1.5rem;
  }

  @media (max-width: 768px) {
    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
    .grid {
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 2rem 1rem;
    }
  }

  @media (max-width: 480px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
